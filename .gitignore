*.local

# AI coding agents — local state directories (auth tokens, worktrees,
# conversation history, scratch). Project-level instructions like
# CLAUDE.md and AGENTS.md are shared docs and DO ship.
.claude/
.cursor/
.cursorignore
.cursorrules
.zed/
.windsurf/
.windsurfrules
.aider*
.continue/
.codium*
.qodo/
.tabnine*
.github/copilot-chat-history.md

# Local test scratch — fixtures, recorded traces, ad-hoc captures the
# agents drop here. Per-crate integration tests under `crates/*/tests/`
# still ship; this root-level `tests/` is workspace scratch space.
/tests/

# Internal / agent-facing meta — kept locally as the working memory of
# the project, NOT published. The public repo is product code only.
# (Files stay on disk; this just keeps them out of git going forward.)
/.agent/
/AGENTS.md
/CLAUDE.md
/decisions/
/proposals/
/research/
/skills/
/docs/
/scripts/
/state.json
/state.schema.json

# Environment / secrets
.env
.env.local
.env.*.local

# Logs
*.log

# Identity material — NEVER commit private keys
identity/private/
*.priv
*.pem
