# Rust build artifacts
/target/
**/target/
**/*.rs.bk
*.pdb

# Cargo
# Cargo.lock is kept (workspace contains binary crates)

# IDE / editor
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Local-only state
heso-local-data/
*.local

# AI coding agents — local state directories (auth tokens, worktrees,
# conversation history, scratch). Project-level instructions like
# CLAUDE.md and AGENTS.md are shared docs and DO ship.
.claude/
.cursor/
.cursorignore
.cursorrules
.zed/
.windsurf/
.windsurfrules
.aider*
.continue/
.codium*
.qodo/
.tabnine*
.github/copilot-chat-history.md

# Local test scratch — fixtures, recorded traces, ad-hoc captures the
# agents drop here. Per-crate integration tests under `crates/*/tests/`
# still ship; this root-level `tests/` is workspace scratch space.
/tests/

# Internal / agent-facing meta — kept locally as the working memory of
# the project, NOT published. The public repo is product code only.
# (Files stay on disk; this just keeps them out of git going forward.)
/.agent/
/AGENTS.md
/CLAUDE.md
/decisions/
/proposals/
/research/
/skills/
/docs/
/state.json
/state.schema.json

# Release pipeline lives at /scripts/ — entire directory is local-only.
# Holds the filled-in release.ps1 with tokens, scratch logs, anything
# else operations-related. Never published. CI in .github/workflows/
# is the canonical release path.
/scripts/

# Release scratch — fresh per release run.
/dist/

# Agent-process scratch — testing reports, regression dumps, scratch
# JSON outputs from running heso against fixtures. Keep them on disk
# while iterating; never commit.
/AGENT_FINDINGS*.md
/REGRESSION_*.md
/REGRESSION_*.json
/COMPATIBILITY.md
/tm*.json
/todomvc.json

# Environment / secrets
.env
.env.local
.env.*.local

# Logs
*.log

# Demo scaffolding is local-only — only the embedded GIF ships publicly.
# Agents / future contributors find the source via .pr-test/ (also ignored).
/demo/agent.py
/demo/record.py
/demo/demo.cast
/demo/demo.mp4
/demo/.palette.png
/demo/README.md

# Benchmarks are local-only. They were useful for design decisions but
# don't belong in the public repo until they're presented cleanly.
/bench/

# Agent scratch: where past demos, recordings, bench runs, and other
# experiments live for future Claude/Codex/Cursor sessions to learn
# from. Never published. See .pr-test/README.md (also local-only) for
# the layout convention.
/.pr-test/

# Identity material — NEVER commit private keys
identity/private/
*.priv
*.pem

# Bundled-binary slots — populated at release time, never committed.
# The PyPI wheel build copies target/release/heso.exe into
# python/heso/bin/; the npm publish step does the same for the
# per-platform package. Source-tree checkouts keep these slots empty
# (the .gitkeep is what's committed) so library callers fall back to
# `heso` on PATH while developing.
/python/heso/bin/heso
/python/heso/bin/heso.exe
/python/heso/bin/*.pdb
/npm/platforms/win32-x64/bin/heso
/npm/platforms/win32-x64/bin/heso.exe

# setuptools build artifacts (from `python -m build` etc.)
/build/
/dist/python/
/python/heso.egg-info/
*.egg-info/

# Python bytecode caches (from `pip install -e .` and import-time)
__pycache__/
*.py[cod]
*$py.class
/npm/platforms/darwin-arm64/bin/heso
/npm/platforms/darwin-arm64/bin/heso.exe
/npm/platforms/darwin-x64/bin/heso
/npm/platforms/darwin-x64/bin/heso.exe
/npm/platforms/linux-arm64/bin/heso
/npm/platforms/linux-arm64/bin/heso.exe
/npm/platforms/linux-x64/bin/heso
/npm/platforms/linux-x64/bin/heso.exe
bug-reports/scratch/
bug-reports/raw/
bug-reports/triage/*.raw
bug-reports/triage/*.json
