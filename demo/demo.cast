[10.259705305099487, "o", "\u001b[1;32m  ok  \u001b[0m\u001b[1;32mtool\u001b[0m\u001b[1;2;32m  2691 ms\u001b[0m\n\u001b[38;2;248;248;242;49m{\u001b[0m\n\u001b[38;2;248;248;242;49m  \u001b[0m\u001b[38;2;255;70;137;49m\"engines_used\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;248;248;242;49m[\u001b[0m\n\u001b[38;2;248;248;242;49m    \u001b[0m\u001b[38;2;230;219;116;49m\"ddg\"\u001b[0m\u001b[38;2;248;248;242;49m,\u001b[0m\n\u001b[38;2;248;248;242;49m    \u001b[0m\u001b[38;2;230;219;116;49m\"wiki\"\u001b[0m\n\u001b[38;2;248;248;242;49m  \u001b[0m\u001b[38;2;248;248;242;49m],\u001b[0m\n\u001b[38;2;248;248;242;49m  \u001b[0m\u001b[38;2;255;70;137;49m\"knowledge\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;102;217;239;49mnull\u001b[0m\u001b[38;2;248;248;242;49m,\u001b[0m\n\u001b[38;2;248;248;242;49m  \u001b[0m\u001b[38;2;255;70;137;49m\"query\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;230;219;116;49m\"rust web scraping libraries\"\u001b[0m\u001b[38;2;248;248;242;49m,\u001b[0m\n\u001b[38;2;248;248;242;49m  \u001b[0m\u001b[38;2;255;70;137;49m\"results\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;248;248;242;49m[\u001b[0m\n\u001b[38;2;248;248;242;49m    \u001b[0m\u001b[38;2;248;248;242;49m{\u001b[0m\n\u001b[38;2;248;248;242;49m      \u001b[0m\u001b[38;2;255;70;137;49m\"rank\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;174;129;255;49m1\u001b[0m\u001b[38;2;248;248;242;49m,\u001b[0m\n\u001b[38;2;248;248;242;49m      \u001b[0m\u001b[38;2;255;70;137;49m\"snippet\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;230;219;116;49m\"Rust web scraping explained for beginners: learn how to scrape websites with Rust, parse \u001b[0m\n\u001b[38;2;230;219;116;49mHTML, handle JavaScript pages, and know when to use scraping APIs.\"\u001b[0m\u001b[38;2;248;248;242;49m,\u001b[0m\n\u001b[38;2;248;248;242;49m      \u001b[0m\u001b[38;2;255;70;137;49m\"source\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;230;219;116;49m\"ddg\"\u001b[0m\u001b[38;2;248;248;242;49m,\u001b[0m\n\u001b[38;2;248;248;242;49m      \u001b[0m\u001b[38;2;255;70;137;49m\"title\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;230;219;116;49m\"Rust web scraping: Complete beginner guide\"\u001b[0m\u001b[38;2;248;248;242;49m,\u001b[0m\n\u001b[38;2;248;248;242;49m      \u001b[0m\u001b[38;2;255;70;137;49m\"url\"\u001b[0m\u001b[38;2;248;248;242;49m:\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;230;219;116;49m\"https://www.scrapingbee.com/blog/web-scraping-rust/\"\u001b[0m\n\u001b[38;2;248;248;242;49m    \u001b[0m\u001b[38;2;248;248;242;49m},\u001b[0m\n\u001b[38;2;248;248;242;49m   \u001b[0m\u001b[38;2;237;0;126;49m.\u001b[0m\u001b[38;2;237;0;126;49m.\u001b[0m\u001b[38;2;237;0;126;49m.\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;237;0;126;49m(\u001b[0m\u001b[38;2;174;129;255;49m65\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;237;0;126;49mm\u001b[0m\u001b[38;2;237;0;126;49mo\u001b[0m\u001b[38;2;237;0;126;49mr\u001b[0m\u001b[38;2;237;0;126;49me\u001b[0m\u001b[38;2;248;248;242;49m \u001b[0m\u001b[38;2;237;0;126;49ml\u001b[0m\u001b[38;2;237;0;126;49mi\u001b[0m\u001b[38;2;102;217;239;49mnes\u001b[0m\u001b[38;2;237;0;126;49m)\u001b[0m\n"]
