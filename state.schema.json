{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/akku41809/heso/state.schema.json",
  "title": "heso project state",
  "description": "Schema for the project-level state.json. Tracks current focus, milestones, tasks, open questions, blockers, and pending decisions. Designed to be safely mutated by AI agents and human contributors alike.",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "meta",
    "current_focus",
    "milestones",
    "tasks"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to this schema. Conventional, ignored by validators."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of the state schema itself. Bump major when making breaking changes."
    },
    "project": {
      "type": "object",
      "required": ["name", "tagline", "category", "phase"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "category": { "type": "string" },
        "phase": {
          "type": "string",
          "description": "Free-form short label for the current high-level phase (e.g. 'M0-skeleton', 'M1-render', 'beta')."
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["updated_at", "updated_by"],
      "additionalProperties": false,
      "properties": {
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of the last update to this file."
        },
        "updated_by": {
          "type": "string",
          "description": "Identifier of the agent or human who last updated. Examples: 'claude-opus-4-7', 'akshay', 'codex'."
        }
      }
    },
    "current_focus": {
      "type": "object",
      "required": ["milestone_id", "summary"],
      "additionalProperties": false,
      "properties": {
        "milestone_id": {
          "type": "string",
          "description": "The milestone currently being worked on. Must reference an entry in `milestones[].id`."
        },
        "summary": {
          "type": "string",
          "description": "One-paragraph human-readable summary of what's happening right now."
        },
        "next_action_id": {
          "type": ["string", "null"],
          "description": "The single most important task to do next. Must reference an entry in `tasks[].id`, or null."
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": { "$ref": "#/$defs/milestone" },
      "description": "Coarse-grained groupings of work. Ordered by ID convention (M0, M1, ...)."
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" },
      "description": "Individual units of work. Cross-link to ADRs, research, and files via the `links` field."
    },
    "open_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/open_question" },
      "default": []
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocker" },
      "default": []
    },
    "decisions_pending": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision_pending" },
      "default": [],
      "description": "Decisions that need to be made and eventually captured as an ADR."
    },
    "log": {
      "type": "array",
      "items": { "$ref": "#/$defs/log_entry" },
      "default": [],
      "description": "Append-only changelog of significant state mutations. Useful for audit and for newcomer agents to see recent activity."
    }
  },
  "$defs": {
    "id_milestone": {
      "type": "string",
      "pattern": "^M\\d+$",
      "description": "Milestone IDs follow the pattern M0, M1, ..."
    },
    "id_task": {
      "type": "string",
      "pattern": "^T-\\d{3,}$",
      "description": "Task IDs follow the pattern T-001, T-002, ..."
    },
    "id_question": {
      "type": "string",
      "pattern": "^Q-\\d{3,}$"
    },
    "id_blocker": {
      "type": "string",
      "pattern": "^B-\\d{3,}$"
    },
    "id_decision": {
      "type": "string",
      "pattern": "^D-\\d{3,}$"
    },
    "id_adr": {
      "type": "string",
      "pattern": "^\\d{4}$",
      "description": "ADR IDs are zero-padded 4-digit numbers, matching the filenames in decisions/."
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"],
      "description": "P0 = critical / now, P1 = important / soon, P2 = nice-to-have, P3 = parking lot."
    },
    "status": {
      "type": "string",
      "enum": ["todo", "in_progress", "blocked", "done", "cancelled"]
    },
    "milestone_status": {
      "type": "string",
      "enum": ["todo", "in_progress", "achieved", "cancelled"]
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adr": {
          "type": "array",
          "items": { "$ref": "#/$defs/id_adr" },
          "default": []
        },
        "research": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Path relative to research/, without .md extension. Example: 'servo-internals/servo-crate-v0-1-0'."
          },
          "default": []
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Path relative to repo root. Example: 'crates/heso-engine-api/src/lib.rs'."
          },
          "default": []
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "GitHub issue URL or number."
          },
          "default": []
        },
        "rfcs": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "RFC ID matching a file in proposals/."
          },
          "default": []
        }
      }
    },
    "milestone": {
      "type": "object",
      "required": ["id", "title", "status", "exit_criteria"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id_milestone" },
        "title": { "type": "string" },
        "status": { "$ref": "#/$defs/milestone_status" },
        "target_date": {
          "type": ["string", "null"],
          "format": "date",
          "description": "ISO-8601 date or null if not yet scheduled."
        },
        "exit_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Concrete, checkable conditions that mean this milestone is done."
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "priority",
        "milestone",
        "owner",
        "created_at",
        "updated_at",
        "depends_on",
        "links"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id_task" },
        "title": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "priority": { "$ref": "#/$defs/priority" },
        "milestone": { "$ref": "#/$defs/id_milestone" },
        "owner": {
          "type": "string",
          "description": "Free-form identifier of the person or agent responsible. Examples: 'akshay', 'claude', 'codex', 'unassigned'."
        },
        "created_at": {
          "type": "string",
          "format": "date",
          "description": "ISO-8601 date."
        },
        "updated_at": {
          "type": "string",
          "format": "date"
        },
        "depends_on": {
          "type": "array",
          "items": { "$ref": "#/$defs/id_task" },
          "default": []
        },
        "links": { "$ref": "#/$defs/links" },
        "notes": {
          "type": "string",
          "description": "Free-form notes. Anything an agent needs to know to do this task that isn't obvious from the title."
        }
      }
    },
    "open_question": {
      "type": "object",
      "required": ["id", "question", "context", "raised_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id_question" },
        "question": { "type": "string" },
        "context": {
          "type": "string",
          "description": "Why this matters and what we already know."
        },
        "raised_at": {
          "type": "string",
          "format": "date"
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/id_task" },
          "default": [],
          "description": "Tasks that cannot proceed until this question is answered."
        },
        "links": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "research": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            },
            "adr": {
              "type": "array",
              "items": { "$ref": "#/$defs/id_adr" },
              "default": []
            }
          }
        }
      }
    },
    "blocker": {
      "type": "object",
      "required": ["id", "title", "raised_at", "blocking_tasks"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id_blocker" },
        "title": { "type": "string" },
        "description": {
          "type": "string"
        },
        "raised_at": {
          "type": "string",
          "format": "date"
        },
        "blocking_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/id_task" },
          "minItems": 1
        },
        "resolution_owner": {
          "type": "string",
          "description": "Who is on the hook to unblock this."
        }
      }
    },
    "decision_pending": {
      "type": "object",
      "required": ["id", "topic", "summary", "raised_at", "needs_adr"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id_decision" },
        "topic": { "type": "string" },
        "summary": { "type": "string" },
        "raised_at": {
          "type": "string",
          "format": "date"
        },
        "needs_adr": {
          "type": "boolean",
          "description": "If true, the resolution should be captured as an ADR in decisions/."
        },
        "blocks_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/id_task" },
          "default": []
        }
      }
    },
    "log_entry": {
      "type": "object",
      "required": ["at", "by", "action"],
      "additionalProperties": false,
      "properties": {
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "by": {
          "type": "string",
          "description": "Identifier of the agent or human. Examples: 'claude-opus-4-7', 'akshay'."
        },
        "action": {
          "type": "string",
          "description": "Short verb-phrase describing what happened. Examples: 'created', 'updated', 'completed', 'blocked', 'unblocked', 'cancelled', 'reprioritized'."
        },
        "target": {
          "type": "string",
          "description": "ID of the milestone, task, question, etc. that was acted on. May be omitted for repo-wide actions."
        },
        "note": {
          "type": "string",
          "description": "Free-form one-liner explaining the change."
        }
      }
    }
  }
}
